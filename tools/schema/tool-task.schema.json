{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://via-decide.dev/schemas/tool-task.schema.json",
  "title": "ViaDecide Tool Task Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "repo",
    "mode",
    "target_files",
    "validation_command",
    "commit_policy",
    "expected_outputs",
    "pass_criteria"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9._:-]+$"
    },
    "repo": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9_.-]+\/[a-zA-Z0-9_.-]+$"
    },
    "mode": {
      "type": "string",
      "enum": [
        "generate",
        "refactor",
        "debug",
        "validate",
        "test",
        "document",
        "package",
        "deploy_prepare",
        "security_scan"
      ]
    },
    "target_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation_command": {
      "type": "string",
      "minLength": 1
    },
    "commit_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["on_validation_pass", "on_validation_fail"],
      "properties": {
        "on_validation_pass": {
          "type": "string",
          "enum": ["commit", "no_commit"]
        },
        "on_validation_fail": {
          "type": "string",
          "enum": ["commit", "no_commit"]
        },
        "commit_message": {
          "type": "string"
        }
      }
    },
    "expected_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "pass_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
